<Window x:Class="DivaModManager.UI.SongManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        xmlns:local="clr-namespace:DivaModManager"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MEGA39+ 歌曲管理"
        Width="1180"
        Height="720"
        MinWidth="960"
        MinHeight="600"
        Background="#202020"
        Foreground="#F2F2F2"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Closed="Window_Closed">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#252525" />
        <SolidColorBrush x:Key="InputBrush" Color="#303030" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3C3C3C" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A8A8A8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3CA7A0" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B44747" />

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="CaretBrush" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               Text="▼" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="260"
                                        Margin="0,2,0,0"
                                        Background="{StaticResource InputBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DropDownToggle" Property="Opacity" Value="0.45" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DropDownToggle" Property="BorderBrush" Value="#686868" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3B4746" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#287B76" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,3" />
            <Setter Property="Background" Value="#424242" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Background" Value="#287B76" />
            <Setter Property="BorderBrush" Value="#3CA7A0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#319089" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Background" Value="#753838" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8D4141" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScopeToggleStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ScopeBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ScopeBorder" Property="Background" Value="#287B76" />
                                <Setter TargetName="ScopeBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ScopeBorder" Property="BorderBrush" Value="#686868" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="Foreground" Value="#D8D8D8" />
            <Setter Property="BorderBrush" Value="#414141" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Foreground"
                    Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="BorderBrush" Value="#343434" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#315B58" />
                    <Setter Property="BorderBrush" Value="#467A76" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#232323" />
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="ToolTip" Value="{Binding RunStatusTooltip}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#272727" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#303A39" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#315B58" />
                </Trigger>
                <DataTrigger Binding="{Binding RunStatus}" Value="{x:Static local:SongRunStatus.Warning}">
                    <Setter Property="Foreground" Value="#FFD166" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RunStatus}" Value="{x:Static local:SongRunStatus.Broken}">
                    <Setter Property="Foreground" Value="#FF6B6B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <DataTemplate x:Key="SongSourcePathTemplate">
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="#E8E8E8"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="{Binding DisplayName}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DisplayName}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               Text="{Binding SourcePath}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding SourcePath}" />
                </StackPanel>
                <Button Grid.Column="2"
                        Width="28"
                        Height="28"
                        Padding="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource CommandButtonStyle}"
                        Tag="{Binding SourcePath}"
                        ToolTip="在资源管理器中定位"
                        Click="RelatedSourcePathButton_Click">
                    <fa5:SvgAwesome Width="14"
                                    Height="14"
                                    Foreground="#F2F2F2"
                                    Icon="Solid_FolderOpen" />
                </Button>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="18,15,18,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="21" FontWeight="SemiBold" Text="MEGA39+ 歌曲管理" />
                <TextBlock Margin="0,3,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           Text="仅处理 MEGA39+ Custom Songs；修改前会创建备份" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ImportButton"
                        Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="导入 MM+ 歌曲包"
                        Click="ImportButton_Click" />
                <Button x:Name="RefreshButton"
                        Style="{StaticResource CommandButtonStyle}"
                        Content="刷新"
                        ToolTip="重新扫描歌曲模组"
                        Click="RefreshButton_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1">
            <Grid Margin="18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" MinWidth="220" MaxWidth="380" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <TextBox x:Name="SearchBox"
                             Padding="10,4,34,4"
                             TextChanged="SearchBox_TextChanged" />
                    <TextBlock x:Name="SearchPlaceholder"
                               Margin="11,0,34,0"
                               VerticalAlignment="Center"
                               Foreground="#777777"
                               IsHitTestVisible="False"
                               Text="搜索 PV ID、歌名、作者或模组" />
                    <Button x:Name="ClearSearchButton"
                            Width="30"
                            Height="30"
                            Margin="0,1,1,1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#BEBEBE"
                            FontSize="18"
                            Content="×"
                            ToolTip="清除搜索"
                            Visibility="Collapsed"
                            Click="ClearSearchButton_Click" />
                </Grid>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" Orientation="Horizontal">
                    <RadioButton x:Name="SelectedModScopeButton"
                                 GroupName="SongScope"
                                 Style="{StaticResource ScopeToggleStyle}"
                                 Content="选中模组"
                                 ToolTip="只显示打开此窗口时选中的模组"
                                 Checked="ScopeButton_Checked" />
                    <RadioButton x:Name="AllModsScopeButton"
                                 GroupName="SongScope"
                                 Style="{StaticResource ScopeToggleStyle}"
                                 Content="全部模组"
                                 IsChecked="True"
                                 Checked="ScopeButton_Checked" />
                </StackPanel>

                <ComboBox x:Name="DifficultyFilterBox"
                          Grid.Column="2"
                          Width="126"
                          Margin="12,0,0,0"
                          DisplayMemberPath="DisplayName"
                          ToolTip="按谱面难度筛选"
                          SelectionChanged="FilterComboBox_SelectionChanged" />

                <ComboBox x:Name="LevelFilterBox"
                          Grid.Column="3"
                          Width="94"
                          Margin="8,0,0,0"
                          DisplayMemberPath="DisplayName"
                          ToolTip="按谱面等级筛选；超出 1–10 或格式异常的等级归为 ?"
                          SelectionChanged="FilterComboBox_SelectionChanged" />

                <ComboBox x:Name="RunStatusFilterBox"
                          Grid.Column="4"
                          Width="116"
                          Margin="8,0,0,0"
                          DisplayMemberPath="DisplayName"
                          ToolTip="按最终运行判定筛选，包括人工覆盖后的结果"
                          SelectionChanged="FilterComboBox_SelectionChanged" />

                <TextBlock x:Name="CountText"
                           Grid.Column="6"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}"
                           Text="0 首歌曲" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="560" />
                <ColumnDefinition Width="330" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <Grid>
                <DataGrid x:Name="SongGrid"
                          AutoGenerateColumns="False"
                          AlternationCount="2"
                          Background="#232323"
                          BorderThickness="0"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="True"
                          CanUserResizeRows="False"
                          EnableRowVirtualization="True"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          SelectionChanged="SongGrid_SelectionChanged">
                    <DataGrid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="64" Binding="{Binding PvId}" Header="PV ID" />
                        <DataGridTextColumn Width="2*" MinWidth="150" Binding="{Binding SongName}" Header="歌名" />
                        <DataGridTextColumn Width="1.3*" MinWidth="110" Binding="{Binding ModName}" Header="模组" />
                        <DataGridTextColumn Width="90" Binding="{Binding FormatDisplayName}" Header="格式" />
                        <DataGridTextColumn Width="1.2*" MinWidth="100" Binding="{Binding DifficultiesDisplay}" Header="难度" />
                        <DataGridTextColumn Width="126" Binding="{Binding RunStatusDisplay}" Header="运行" />
                        <DataGridTextColumn Width="76" Binding="{Binding AudioStatus}" Header="音频" />
                        <DataGridTextColumn Width="132" Binding="{Binding VideoStatus}" Header="视频" />
                        <DataGridTextColumn Width="70" Binding="{Binding ArtworkStatus}" Header="封面" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid x:Name="ListStatePanel" Background="#E6232323" Visibility="Collapsed">
                    <StackPanel Width="430" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar x:Name="StateProgressBar"
                                     Width="260"
                                     Height="3"
                                     Margin="0,0,0,16"
                                     IsIndeterminate="True"
                                     Foreground="{StaticResource AccentBrush}" />
                        <TextBlock x:Name="StateTitleText"
                                   HorizontalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Text="正在扫描歌曲…" />
                        <TextBlock x:Name="StateMessageText"
                                   Margin="0,7,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <Button x:Name="StateActionButton"
                                Width="100"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource CommandButtonStyle}"
                                Content="重试"
                                Visibility="Collapsed"
                                Click="StateActionButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid x:Name="DetailsPanel" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0"
                                  Margin="0,0,0,12"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock x:Name="DetailsTitleText"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="未选择歌曲"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Margin="0,4,0,14">
                                <TextBlock x:Name="DetailsMetaText"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="请从左侧列表中选择歌曲"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="DetailsAuthorText"
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                             </StackPanel>

                            <TextBlock x:Name="PatchWriteProtectionText"
                                       Margin="0,0,0,14"
                                       Foreground="#FFD166"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="这是歌曲补丁，不能修改歌名或删除；仍可预览图片并打开目录。"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />

                             <Border Margin="0,0,0,14"
                                    Padding="0,0,0,12"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock x:Name="DetailsDifficultiesLabel"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Text="难度谱面" />
                                    <TextBlock x:Name="DetailsDifficultiesText"
                                               Foreground="#E4E4E4"
                                               LineHeight="21"
                                               Text="—"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,14"
                                    Padding="0,0,0,14"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="歌曲图片" />
                                    <UniformGrid Margin="0,0,0,8" Columns="3">
                                        <RadioButton x:Name="ThumbnailArtworkButton"
                                                     GroupName="ArtworkKind"
                                                     Style="{StaticResource ScopeToggleStyle}"
                                                     Content="小图标"
                                                     Checked="ArtworkKind_Checked" />
                                        <RadioButton x:Name="JacketArtworkButton"
                                                     GroupName="ArtworkKind"
                                                     Style="{StaticResource ScopeToggleStyle}"
                                                     Content="封面"
                                                     Checked="ArtworkKind_Checked" />
                                        <RadioButton x:Name="BackgroundArtworkButton"
                                                     GroupName="ArtworkKind"
                                                     Style="{StaticResource ScopeToggleStyle}"
                                                     Content="背景"
                                                     Checked="ArtworkKind_Checked" />
                                    </UniformGrid>
                                    <Border Height="166"
                                            Background="#151515"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Image x:Name="ArtworkPreviewImage"
                                                   Margin="1"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Stretch="Uniform" />
                                            <Grid x:Name="ArtworkPreviewStatePanel" Background="#C0151515">
                                                <StackPanel Margin="14"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <ProgressBar x:Name="ArtworkPreviewProgress"
                                                                 Width="150"
                                                                 Height="3"
                                                                 Margin="0,0,0,10"
                                                                 IsIndeterminate="True"
                                                                 Foreground="{StaticResource AccentBrush}" />
                                                    <TextBlock x:Name="ArtworkPreviewStateText"
                                                               MaxWidth="250"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="请选择歌曲"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="ArtworkPreviewSourceText"
                                               Margin="0,7,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               Text="—"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                                </StackPanel>
                            </Border>

                             <StackPanel Margin="0,0,0,11">
                                 <TextBlock Style="{StaticResource FieldLabelStyle}" Text="歌名" />
                                 <TextBox x:Name="SongNameBox"
                                          IsEnabled="False"
                                          MaxLength="256"
                                          ToolTipService.ShowOnDisabled="True" />
                             </StackPanel>
                             <StackPanel Margin="0,0,0,11">
                                 <TextBlock Style="{StaticResource FieldLabelStyle}" Text="英文名" />
                                 <TextBox x:Name="SongNameEnglishBox"
                                          IsEnabled="False"
                                          MaxLength="256"
                                          ToolTipService.ShowOnDisabled="True" />
                             </StackPanel>
                             <StackPanel Margin="0,0,0,11">
                                 <TextBlock Style="{StaticResource FieldLabelStyle}" Text="读音 / 排序名" />
                                 <TextBox x:Name="SongNameReadingBox"
                                          IsEnabled="False"
                                          MaxLength="256"
                                          ToolTipService.ShowOnDisabled="True" />
                             </StackPanel>

                            <Button x:Name="SaveMetadataButton"
                                    Margin="0,0,0,14"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                     Content="保存歌名"
                                     IsEnabled="False"
                                     ToolTipService.ShowOnDisabled="True"
                                     Click="SaveMetadataButton_Click" />

                            <Border Padding="0,11,0,0"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" Text="运行判定" />
                                    <TextBlock x:Name="DetailsRunStatusText"
                                               Margin="0,5,0,10"
                                               FontWeight="SemiBold"
                                               Text="—"
                                               TextWrapping="Wrap" />

                                    <TextBlock Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               Text="人工运行判定" />
                                    <Grid Margin="0,5,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ManualRunStatusBox"
                                                  DisplayMemberPath="DisplayName"
                                                  IsEnabled="False"
                                                  ToolTip="选择自动判断可清除已保存的人工覆盖" />
                                        <Button x:Name="SaveRunStatusOverrideButton"
                                                Grid.Column="2"
                                                MinWidth="64"
                                                Style="{StaticResource CommandButtonStyle}"
                                                Content="保存"
                                                IsEnabled="False"
                                                Click="SaveRunStatusOverrideButton_Click" />
                                    </Grid>
                                    <TextBlock x:Name="ManualRunStatusHintText"
                                               Margin="0,0,0,10"
                                               Foreground="#76C7C0"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />

                                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" Text="资源状态" />
                                    <TextBlock x:Name="DetailsAssetStatusText"
                                               Margin="0,5,0,0"
                                               Text="—"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="DetailsWarningText"
                                               Margin="0,7,0,0"
                                               Foreground="#E3B05B"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />

                                    <Border x:Name="ConflictSourcesPanel"
                                            Margin="0,11,0,0"
                                            Padding="0,10,0,0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="ConflictSourcesLabel"
                                                       Foreground="#FF8A80"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="PVID 冲突路径" />
                                            <ItemsControl x:Name="ConflictSourcesItems"
                                                          ItemTemplate="{StaticResource SongSourcePathTemplate}" />
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="PatchSourcesPanel"
                                            Margin="0,11,0,0"
                                            Padding="0,10,0,0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="PatchSourcesLabel"
                                                       Foreground="#76C7C0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="已启用的歌曲补丁" />
                                            <ItemsControl x:Name="PatchSourcesItems"
                                                          ItemTemplate="{StaticResource SongSourcePathTemplate}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ReplaceArtworkButton"
                                    Style="{StaticResource CommandButtonStyle}"
                                    Content="替换当前图片"
                                    IsEnabled="False"
                                    ToolTip="选择普通图片；管理器只改写当前 Sprite，并自动备份 FARC"
                                    Click="ReplaceArtworkButton_Click" />
                            <Button x:Name="OpenFolderButton"
                                    Grid.Column="2"
                                    Style="{StaticResource CommandButtonStyle}"
                                    Content="打开目录"
                                    IsEnabled="False"
                                    Click="OpenFolderButton_Click" />
                        </Grid>
                        <Button x:Name="DeleteSongButton"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource DangerButtonStyle}"
                                 Content="删除歌曲"
                                 IsEnabled="False"
                                 ToolTipService.ShowOnDisabled="True"
                                 Click="DeleteSongButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}"
                           Text="就绪"
                           TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1"
                        Width="76"
                        Style="{StaticResource CommandButtonStyle}"
                        Content="关闭"
                        IsCancel="True"
                        Click="CloseButton_Click" />
            </Grid>
        </Border>

        <Border x:Name="OperationOverlay"
                Grid.RowSpan="4"
                Background="#9A151515"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Width="300"
                             Height="4"
                             IsIndeterminate="True"
                             Foreground="{StaticResource AccentBrush}" />
                <TextBlock x:Name="OperationText"
                           Margin="0,14,0,0"
                           HorizontalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Text="正在处理…" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
